<%# Секция ремонта в карточке оборудования %>
<%# Локальные переменные: equipment, system_name (cute/fids/zamar) %>

<% if equipment.repair_ticket_number.present? || equipment.status.to_s.in?(%w[waiting_repair maintenance]) %>
  <div class="bg-white shadow mt-6 rounded-lg mb-6 border-l-4 border-orange-400">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Информация о ремонте</h3>
      <dl class="grid grid-cols-1 sm:grid-cols-2" style="gap: 16px;">
        <div>
          <dt class="text-sm font-medium text-gray-500">Статус ремонта</dt>
          <dd class="mt-1">
            <% if equipment.status.to_s == "waiting_repair" %>
              <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                Ожидает ремонта
              </span>
            <% elsif equipment.status.to_s == "maintenance" %>
              <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-orange-100 text-orange-800">
                В ремонте
              </span>
            <% end %>
          </dd>
        </div>
        <% if equipment.repair_ticket_number.present? %>
          <div>
            <dt class="text-sm font-medium text-gray-500">Номер заявки</dt>
            <dd class="mt-1 text-sm text-gray-900 font-medium"><%= equipment.repair_ticket_number %></dd>
          </div>
        <% end %>
      </dl>

      <% if current_user.can_manage? %>
        <div class="mt-4 pt-4 border-t border-gray-200">
          <%= button_to "Вернуть из ремонта",
              polymorphic_path(equipment),
              method: :patch,
              params: { "#{system_name}_equipment": { status: :active } },
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 cursor-pointer",
              data: { turbo_confirm: "Вернуть оборудование из ремонта и установить статус 'В работе'?" } %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if current_user.can_edit? && !equipment.status.to_s.in?(%w[waiting_repair]) %>
  <div class="mt-4 mb-6">
    <button type="button" onclick="document.getElementById('repair-modal-<%= equipment.id %>').classList.remove('hidden')"
            class="inline-flex items-center px-4 py-2 border border-orange-300 rounded-md shadow-sm text-sm font-medium text-orange-700 bg-white hover:bg-orange-50 cursor-pointer">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Отправить в ремонт
    </button>
  </div>

  <!-- Модальное окно отправки в ремонт -->
  <div id="repair-modal-<%= equipment.id %>" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen px-4">
      <div class="fixed inset-0 bg-gray-500 bg-opacity-75" onclick="document.getElementById('repair-modal-<%= equipment.id %>').classList.add('hidden')"></div>
      <div class="relative bg-white rounded-lg shadow-xl max-w-lg w-full p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900">Отправить в ремонт</h3>
          <button type="button" onclick="document.getElementById('repair-modal-<%= equipment.id %>').classList.add('hidden')" class="text-gray-400 hover:text-gray-500">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <%= form_with url: create_batch_repairs_path, method: :post, local: true, class: "space-y-4" do |f| %>
          <input type="hidden" name="equipment_ids[][type]" value="<%= equipment.class.name %>">
          <input type="hidden" name="equipment_ids[][id]" value="<%= equipment.id %>">

          <div>
            <p class="text-sm text-gray-600">
              <strong>Оборудование:</strong> <%= equipment.respond_to?(:equipment_type_text) ? equipment.equipment_type_text : equipment.equipment_type %> — <%= equipment.equipment_model %>
            </p>
            <p class="text-sm text-gray-600">
              <strong>Инв. №:</strong> <%= equipment.inventory_number %> | <strong>С/Н:</strong> <%= equipment.serial_number %>
            </p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Примечание к заявке</label>
            <textarea name="repair_note" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" placeholder="Описание неисправности..."></textarea>
          </div>

          <div class="flex justify-end space-x-3 pt-4 border-t">
            <button type="button" onclick="document.getElementById('repair-modal-<%= equipment.id %>').classList.add('hidden')"
                    class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 cursor-pointer">
              Отмена
            </button>
            <%= f.submit "Отправить в ремонт", class: "px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
